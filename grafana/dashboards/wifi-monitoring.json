{
  "title": "WiFi Monitor",
  "uid": "wifi-monitor",
  "tags": [
    "wifi",
    "monitoring"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "ssid",
        "type": "query",
        "query": "label_values(wifi_ap_signal_dbm, ssid)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 3,
        "definition": "label_values(wifi_ap_signal_dbm, ssid)"
      },
      {
        "name": "band",
        "type": "query",
        "query": "label_values(wifi_ap_count, band)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "definition": "label_values(wifi_ap_count, band)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Access Points",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(wifi_ap_signal_dbm{type=~'.*AP.*'})",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "Total Devices",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(wifi_ap_signal_dbm)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Avg Signal",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "expr": "avg(wifi_ap_signal_dbm)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "dBm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": -67
              },
              {
                "color": "red",
                "value": -80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Channels Used",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(wifi_ap_channel)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Bands",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(wifi_ap_count)",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "title": "Scanner",
      "type": "stat",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "wifi_scanner_up",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "none",
          "mappings": [
            {
              "type": 1,
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto"
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "id": 100,
      "panels": [],
      "title": "Signal & Spectrum",
      "type": "row"
    },
    {
      "id": 10,
      "title": "Signal Strength \u2014 Top 10",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "topk(10, wifi_ap_signal_dbm{type=~\".*AP.*\", band=~\"$band\"})",
          "legendFormat": "{{ssid}} ({{bssid}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": -67
              },
              {
                "color": "red",
                "value": -80
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max",
            "min"
          ],
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "id": 11,
      "title": "Frequency Distribution",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "topk(20, avg by (ssid) (wifi_ap_frequency_mhz))",
          "legendFormat": "{{ssid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "MHz"
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 12,
      "title": "Devices by Band",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "targets": [
        {
          "expr": "wifi_ap_count{band='2.4 GHz'}",
          "legendFormat": "2.4 GHz"
        },
        {
          "expr": "wifi_ap_count{band='5 GHz'}",
          "legendFormat": "5 GHz"
        },
        {
          "expr": "wifi_ap_count{band='6 GHz'}",
          "legendFormat": "6 GHz"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "none"
        }
      },
      "options": {
        "orientation": "vertical",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 101,
      "panels": [],
      "title": "Channel Details",
      "type": "row"
    },
    {
      "id": 20,
      "title": "All Detected APs",
      "type": "table",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "expr": "avg by (ssid, bssid, type) (wifi_ap_signal_dbm)",
          "legendFormat": "{{ssid}}",
          "refId": "A"
        }
      ],
      "transformations": [],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "left",
            "displayMode": "color-background",
            "filterable": true
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": -67
              },
              {
                "color": "red",
                "value": -80
              }
            ]
          },
          "unit": "dBm"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "ssid"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "auto"
              },
              {
                "id": "unit",
                "value": "none"
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Value"
          }
        ]
      }
    },
    {
      "id": 21,
      "title": "Signal per Channel",
      "type": "bargauge",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "avg by (ssid) (wifi_ap_signal_dbm)",
          "legendFormat": "{{ssid}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dBm",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    }
  ]
}