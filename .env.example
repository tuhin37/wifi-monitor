# Wi-Fi Monitor — Environment Configuration
# Copy to .env and edit:
#   cp .env.example .env

# --- Scanner ---
SCANNER_INTERFACE=wlan1
SCANNER_BACKEND=kismet
KISMET_URL=http://127.0.0.1:2501
KISMET_USERNAME=admin
KISMET_PASSWORD=admin
POLL_INTERVAL=15

# --- WiFi Management (for speed test tasks) ---
MGMT_INTERFACE=wlan0
WIFI_BACKEND=nmcli

# --- Speed Test ---
SPEEDTEST_BACKEND=speedtest-cli
# IPERF3_SERVER=your-iperf3-server

# --- Exporter ---
EXPORTER_PORT=8501
DATA_DIR=/data

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
