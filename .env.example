# =============================================================================
# WiFi Monitor Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and edit for your environment:
#   cp .env.example .env
# =============================================================================

# --- Kismet REST API Credentials ---
# These must match what Kismet is configured to use.
# Default Kismet credentials are admin / admin.
KISMET_USERNAME=admin
KISMET_PASSWORD=admin

# --- Exporter ---
EXPORTER_PORT=8501
# Wireless interface on the HOST for iw survey dump (channel utilization).
# Leave empty to disable channel utilization reporting.
# Example: WIFI_INTERFACE=wlan1
WIFI_INTERFACE=
# How often to poll Kismet for new device data (seconds)
POLL_INTERVAL=15

# --- Prometheus ---
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d

# --- Grafana ---
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
